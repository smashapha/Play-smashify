{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a Smashify listener or artist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "is_artist": { "type": "boolean" },
        "stage_name": { "type": "string" },
        "genre": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "subscription_tier": { "type": "string" },
        "wallet_balance": { "type": "number" },
        "created_at": { "type": "number" },
        "id_photo_url": { "type": "string" }
      },
      "required": ["full_name", "email", "is_artist", "created_at"]
    },
    "Song": {
      "title": "Song",
      "description": "A musical track uploaded by an artist",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "genre": { "type": "string" },
        "artist_id": { "type": "string" },
        "artist_name": { "type": "string" },
        "is_for_sale": { "type": "boolean" },
        "price": { "type": "number" },
        "lyrics": { "type": "string" },
        "cover_art_url": { "type": "string" },
        "audio_url": { "type": "string" },
        "streams": { "type": "number" },
        "revenue": { "type": "number" },
        "created_at": { "type": "number" },
        "status": { "type": "string" },
        "album_title": { "type": "string" }
      },
      "required": ["title", "artist_id", "artist_name", "audio_url", "created_at", "status"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles stored by their auth UID"
    },
    "/songs/{songId}": {
      "schema": { "$ref": "#/entities/Song" },
      "description": "Songs uploaded by artists"
    }
  }
}
